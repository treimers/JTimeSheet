{
  "_fileDescription": "Testfälle für ReminderSuggestionLogic.compute(…). Prüft die vollständige Vorschlagslogik: Kunde/Projekt/Task, Zeitbereich (DEFAULT_RANGE vs GAP), blockedForReminder. Szenarien 1–7 (keine Aktivität heute, erste Kunde/Projekt/Task, letztes Ende in Vergangenheit/Zukunft, Add Activity, Kundenwechsel, SuggestionType).",
  "_structure": "defaultSettings (windowStart, windowEnd, timeGridMinutes, weekdays); computeCases[]: description, setup (customers[], activities[]), input (now, lastActivityIndex, contextCustomerId, contextProjectId, fromReminder), expected (blockedForReminder, suggestionType, customerId, projectId, taskId, range, rangeEndIsNow, rangeStartBeforeNow, rangeStartEqualsEnd, rangeNotNull).",
  "defaultSettings": {
    "windowStart": "09:00",
    "windowEnd": "17:00",
    "timeGridMinutes": 15,
    "weekdays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"]
  },
  "computeCases": [
    {
      "description": "Szenario 3: Letztes Ende nicht in Zukunft → letztes Ende als Vorschlags-Start (keine Lückensuche)",
      "setup": {
        "customers": [
          { "id": "C", "name": "C", "projects": [ { "id": "P", "name": "P", "tasks": [ { "id": "T", "name": "T" } ] } ] }
        ],
        "activities": [
          { "customerId": "C", "projectId": "P", "taskId": "T", "from": "2025-02-03T11:00", "to": "2025-02-03T12:30" }
        ]
      },
      "input": {
        "now": "2025-02-03T13:00",
        "lastActivityIndex": null,
        "contextCustomerId": null,
        "contextProjectId": null,
        "fromReminder": true
      },
      "expected": {
        "blockedForReminder": false,
        "suggestionType": "GAP",
        "customerId": "C",
        "projectId": "P",
        "taskId": "T",
        "range": ["2025-02-03T12:30", "2025-02-03T13:00"]
      }
    },
    {
      "description": "Szenario 5: Letztes Ende in Zukunft (Add Activity) → Lücke wird gesucht und vorgeschlagen",
      "setup": {
        "customers": [
          { "id": "C", "name": "C", "projects": [ { "id": "P", "name": "P", "tasks": [ { "id": "T", "name": "T" } ] } ] }
        ],
        "activities": [
          { "customerId": "C", "projectId": "P", "taskId": "T", "from": "2025-02-03T10:00", "to": "2025-02-03T12:00" }
        ]
      },
      "input": {
        "now": "2025-02-03T09:00",
        "lastActivityIndex": null,
        "contextCustomerId": null,
        "contextProjectId": null,
        "fromReminder": false
      },
      "expected": {
        "blockedForReminder": false,
        "suggestionType": "GAP",
        "rangeEndIsNow": true,
        "rangeStartBeforeNow": true
      }
    },
    {
      "description": "Szenario 1: Letzter Kunde und DEFAULT_RANGE (now−1h, now)",
      "setup": {
        "customers": [
          { "id": "A", "name": "A", "projects": [] },
          { "id": "B", "name": "B", "projects": [ { "id": "P2", "name": "P2", "tasks": [ { "id": "T2", "name": "T2" } ] } ] }
